@page "/"
@using FabrCore.Client.Components

<PageTitle>Home</PageTitle>

<h1>Welcome</h1>

<p>Chat with your AI agent using the dock in the bottom-right corner.</p>

<!-- Basic ChatDock usage -->
<ChatDock UserHandle="user1"
          AgentHandle="assistant"
          AgentType="my-agent"
          SystemPrompt="You are a helpful assistant."
          Title="Assistant"
          Position="ChatDockPosition.BottomRight" />

