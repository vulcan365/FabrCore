{
  "FabrCore": {
    "VerifiableExecution": {
      "Enabled": true,
      "DefaultPropagationScope": "Lineage",
      "RequireSignerForTrustedExecution": true,
      "RequireSpiffeForDaprParity": false,
      "RequireAttestedExternalEffects": false,
      "CapturePayloadBytes": false,
      "FailOnVerificationError": true,
      "MaxMetadataValueLength": 4096,
      "Signer": {
        "Type": "LocalCertificate",
        "CertificateThumbprint": "",
        "KeyVaultKeyId": "",
        "SpiffeSocketPath": "unix:///run/spire/sockets/agent.sock"
      },
      "Store": {
        "Type": "Sql",
        "ConnectionStringName": "VerifiableExecution"
      }
    }
  }
}
