{
  "ModelConfigurations": [
    {
      "Name": "AzureProd",
      "Provider": "Azure",
      "Uri": "https://your-resource.cognitiveservices.azure.com/",
      "Model": "gpt-4.1-mini",
      "ApiKeyAlias": "AZURE_KEY",
      "ReasoningEffort": "none",
      "MaxOutputTokens": 1000
    },
    {
      "Name": "OpenAIProd",
      "Provider": "OpenAI",
      "Uri": "https://api.openai.com/v1",
      "Model": "gpt-4.1-mini",
      "ApiKeyAlias": "OPENAI_KEY",
      "TimeoutSeconds": 60,
      "MaxOutputTokens": 2048,
      "ReasoningEffort": "none"
    }
  ],
  "ApiKeys": [
    {
      "Alias": "AZURE_KEY",
      "Value": "your-azure-api-key-here"
    },
    {
      "Alias": "OPENAI_KEY",
      "Value": "your-openai-api-key-here"
    }
  ],
  "Microsoft365Copilot": {
    "TenantId": "your-entra-tenant-id",
    "ClientId": "your-bot-app-registration-client-id",
    "ClientSecret": "your-bot-app-registration-secret",
    "Agent": {
      "AgentType": "chat-agent",
      "SystemPrompt": "You are a helpful assistant.",
      "Models": "default"
    },
    "Proactive": {
      "Enabled": false,
      "AllowedConversationTypes": [ "personal" ]
    },
    "Manifest": {
      "Name": "My FabrCore Agent",
      "Description": "Answers questions using my FabrCore agents.",
      "PublicHostName": "your-public-host.example.com"
    }
  }
}
