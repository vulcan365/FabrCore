@using FabrCore.Client
@using FabrCore.Client.Services
@using FabrCore.Core
@using Markdig
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.Logging
@inject IClientContextFactory ClientContextFactory
@inject IJSRuntime JSRuntime
@inject ILogger<ChatDock> Logger
@implements IAsyncDisposable

<button type="button"
        class="chat-dock-icon @GetIconStateClass()"
        @onclick="ToggleDock"
        aria-label="@GetIconTooltip()"
        aria-expanded="@(_isExpanded ? "true" : "false")"
        aria-haspopup="dialog"
        title="@GetIconTooltip()">
    <i class="@Icon"></i>
    @if (_hasUnreadMessages)
    {
        <span class="chat-dock-badge" aria-label="Unread messages"></span>
    }
</button>

<div @ref="_panelElement"
     class="chat-dock-panel @GetPositionClass() @GetSizeClass() @(_isExpanded ? "" : "chat-dock-panel-hidden")"
     id="@_panelId"
     role="dialog"
     aria-labelledby="@_titleId">
        <div class="chat-dock-header">
            <div class="chat-dock-title" id="@_titleId">
                <i class="@Icon me-2"></i>
                <span>@Title</span>
            </div>
            <div class="chat-dock-actions">
                <button class="chat-dock-btn" @onclick="CycleSize" title="@GetSizeTooltip()">
                    <i class="@GetSizeIcon()"></i>
                </button>
                <button class="chat-dock-btn" @onclick="ClearMessages" title="Clear chat history (agent memory retained)">
                    <i class="bi bi-trash"></i>
                </button>
                <button class="chat-dock-btn" @onclick="ToggleDock" title="Minimize">
                    <i class="bi bi-dash-lg"></i>
                </button>
            </div>
        </div>

        <div class="chat-dock-messages" @ref="_messagesContainer" role="log" aria-live="polite">
            @if (_messages.Count == 0 && !_isWaitingForResponse && string.IsNullOrEmpty(_thinkingMessage))
            {
                <div class="chat-dock-welcome">
                    <div class="chat-dock-welcome-icon">
                        <i class="@Icon"></i>
                    </div>
                    <p>@WelcomeMessage</p>
                </div>
            }
            else
            {
                @foreach (var message in _messages)
                {
                    <div class="chat-dock-message @(message.IsFromUser ? "chat-dock-message-user" : "chat-dock-message-agent")">
                        <div class="chat-dock-message-avatar">
                            @if (message.IsFromUser)
                            {
                                <i class="bi bi-person-fill"></i>
                            }
                            else
                            {
                                <i class="@Icon"></i>
                            }
                        </div>
                        <div class="chat-dock-message-content">
                            <div class="chat-dock-message-text">
                                @if (message.IsFromUser)
                                {
                                    @message.Text
                                }
                                else
                                {
                                    @((MarkupString)(message.RenderedHtml ?? message.Text))
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(_thinkingMessage))
                {
                    <div class="chat-dock-message chat-dock-message-agent chat-dock-thinking">
                        <div class="chat-dock-message-avatar">
                            <i class="@Icon"></i>
                        </div>
                        <div class="chat-dock-message-content">
                            <div class="chat-dock-message-text chat-dock-typing">
                                <span class="thinking-text">Thinking: @_thinkingMessage</span>
                            </div>
                        </div>
                    </div>
                }
                @if (_isWaitingForResponse)
                {
                    <div class="chat-dock-message chat-dock-message-agent">
                        <div class="chat-dock-message-avatar">
                            <i class="@Icon"></i>
                        </div>
                        <div class="chat-dock-message-content">
                            <div class="chat-dock-message-text chat-dock-typing">
                                <span class="typing-dot"></span>
                                <span class="typing-dot"></span>
                                <span class="typing-dot"></span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="chat-dock-error">
                <i class="bi bi-exclamation-triangle me-1"></i>@_error
                <button class="btn-close btn-close-sm" @onclick="() => _error = null"></button>
            </div>
        }

        <div class="chat-dock-input-container">
            <div class="chat-dock-input-wrapper">
                <textarea class="chat-dock-input"
                          @ref="_textareaElement"
                          value="@_currentMessage"
                          @oninput="OnInput"
                          placeholder="Type a message..."
                          disabled="@(_isWaitingForResponse || !_isConnected)"
                          rows="1"></textarea>
                <button class="chat-dock-send-btn"
                        @onclick="SendMessage"
                        disabled="@(_isWaitingForResponse || string.IsNullOrWhiteSpace(_currentMessage) || !_isConnected)">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div class="chat-dock-status">
                @if (_isConnected)
                {
                    <span class="status-connected" title="@GetHealthTooltip()">
                        <i class="bi bi-circle-fill @GetHealthColorClass()"></i> @GetHealthStatusText()
                    </span>
                    @if (_agentHealth?.MessagesProcessed != null && _agentHealth.MessagesProcessed > 0)
                    {
                        <span class="status-messages ms-2" title="Messages processed">
                            <i class="bi bi-chat-square-text"></i> @_agentHealth.MessagesProcessed.Value.ToString("N0")
                        </span>
                    }
                }
                else if (_isConnecting)
                {
                    <span class="status-connecting"><i class="bi bi-circle-fill"></i> Connecting...</span>
                }
                else
                {
                    <span class="status-disconnected">
                        <i class="bi bi-circle-fill"></i> Disconnected
                        <button class="btn btn-link btn-sm p-0 ms-1" @onclick="ConnectAsync">Retry</button>
                    </span>
                }
            </div>
        </div>
    </div>

@code {
    /// <summary>
    /// The user handle/identifier for the current user. This is required.
    /// </summary>
    [Parameter, EditorRequired]
    public string UserHandle { get; set; } = string.Empty;

    /// <summary>
    /// The agent handle to connect to (e.g., "document-agent", "curia").
    /// </summary>
    [Parameter, EditorRequired]
    public string AgentHandle { get; set; } = string.Empty;

    /// <summary>
    /// The agent type to create (e.g., "DocumentAgent", "CuriaAgent").
    /// </summary>
    [Parameter, EditorRequired]
    public string AgentType { get; set; } = string.Empty;

    /// <summary>
    /// The system prompt for the agent.
    /// </summary>
    [Parameter]
    public string SystemPrompt { get; set; } = "You are a helpful AI assistant.";

    /// <summary>
    /// Display title for the chat dock.
    /// </summary>
    [Parameter]
    public string Title { get; set; } = "Assistant";

    /// <summary>
    /// Bootstrap icon class for the dock icon.
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = "bi bi-chat-dots";

    /// <summary>
    /// Welcome message shown when chat is empty.
    /// </summary>
    [Parameter]
    public string WelcomeMessage { get; set; } = "How can I help you today?";

    /// <summary>
    /// Tooltip shown on hover over the icon.
    /// </summary>
    [Parameter]
    public string Tooltip { get; set; } = "Open chat";

    /// <summary>
    /// Position where the chat panel appears on screen.
    /// </summary>
    [Parameter]
    public ChatDockPosition Position { get; set; } = ChatDockPosition.BottomRight;

    /// <summary>
    /// Additional arguments to pass to the agent configuration.
    /// These are merged with the default args (userId is always included).
    /// </summary>
    [Parameter]
    public Dictionary<string, string>? AdditionalArgs { get; set; }

    /// <summary>
    /// When true, defers agent creation until the dock is first expanded.
    /// Useful when rendering many ChatDock components (e.g., in table rows)
    /// to avoid creating agents that may never be used.
    /// </summary>
    [Parameter]
    public bool LazyLoad { get; set; }

    /// <summary>
    /// Plugin aliases to enable for this agent.
    /// </summary>
    [Parameter]
    public List<string>? Plugins { get; set; }

    /// <summary>
    /// Standalone tool aliases to enable for this agent.
    /// </summary>
    [Parameter]
    public List<string>? Tools { get; set; }

    /// <summary>
    /// Callback invoked when the agent sends a non-thinking message to this chat dock.
    /// Receives the full AgentMessage including metadata such as FromHandle, MessageType, and State.
    /// Return <c>true</c> to display the message in the chat history, or <c>false</c> to suppress it
    /// (e.g., for status/state messages that should only update parent component state).
    /// When not set, all non-thinking messages are displayed in chat.
    /// </summary>
    [Parameter]
    public Func<AgentMessage, Task<bool>>? OnMessageReceived { get; set; }

    /// <summary>
    /// Callback invoked when the user sends a message from this chat dock.
    /// Provides the trimmed message text that was sent.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnMessageSent { get; set; }

    /// <summary>
    /// Manager for coordinating multiple chat docks.
    /// </summary>
    [CascadingParameter]
    public ChatDockManager? DockManager { get; set; }

    private static readonly MarkdownPipeline _markdownPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .Build();

    private IClientContext? _clientContext;
    private List<ChatMessage> _messages = new();
    private string _currentMessage = string.Empty;
    private string? _error;
    private string? _thinkingMessage;
    private bool _isWaitingForResponse;
    private bool _isConnected;
    private bool _isConnecting;
    private bool _isExpanded;
    private bool _hasUnreadMessages;
    private bool _agentExists;
    private bool _needsScroll;
    private ChatDockSize _currentSize = ChatDockSize.Medium;
    private ElementReference _messagesContainer;
    private ElementReference _panelElement;
    private ElementReference _textareaElement;
    private CancellationTokenSource? _thinkingFadeCts;
    private AgentHealthStatus? _agentHealth;
    private readonly string _panelId = $"chat-dock-panel-{Guid.NewGuid():N}";
    private readonly string _titleId = $"chat-dock-title-{Guid.NewGuid():N}";
    private IJSObjectReference? _jsModule;

    // B3: Use _panelId (GUID-based) instead of GetHashCode() to avoid collisions
    private string DockId => $"{AgentHandle}_{_panelId}";

    private string GetPositionClass() => Position switch
    {
        ChatDockPosition.BottomLeft => "chat-dock-bottom-left",
        ChatDockPosition.Right => "chat-dock-right",
        ChatDockPosition.Left => "chat-dock-left",
        _ => "chat-dock-bottom-right"
    };

    private string GetSizeClass() => _currentSize switch
    {
        ChatDockSize.Medium => "chat-dock-size-md",
        ChatDockSize.Large => "chat-dock-size-lg",
        _ => ""
    };

    private async Task CycleSize()
    {
        _currentSize = _currentSize switch
        {
            ChatDockSize.Small => ChatDockSize.Medium,
            ChatDockSize.Medium => ChatDockSize.Large,
            ChatDockSize.Large => ChatDockSize.Small,
            _ => ChatDockSize.Small
        };
        await SaveSizePreference();
    }

    private string SizeStorageKey => $"chatdock-size-{AgentHandle}";

    private async Task SaveSizePreference()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", SizeStorageKey, _currentSize.ToString());
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to save size preference");
        }
    }

    private async Task LoadSizePreference()
    {
        try
        {
            var stored = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", SizeStorageKey);
            if (stored != null && Enum.TryParse<ChatDockSize>(stored, out var size))
            {
                _currentSize = size;
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to load size preference");
        }
    }

    private string GetSizeIcon() => _currentSize switch
    {
        ChatDockSize.Small => "bi bi-arrows-angle-expand",
        ChatDockSize.Medium => "bi bi-arrows-fullscreen",
        ChatDockSize.Large => "bi bi-arrows-angle-contract",
        _ => "bi bi-arrows-angle-expand"
    };

    private string GetSizeTooltip() => _currentSize switch
    {
        ChatDockSize.Small => "Expand to medium",
        ChatDockSize.Medium => "Expand to large",
        ChatDockSize.Large => "Shrink to small",
        _ => "Resize"
    };

    private string GetIconStateClass()
    {
        if (_isExpanded) return "is-open";
        if (_hasUnreadMessages) return "has-unread";
        if (_isConnected) return "is-connected";
        if (LazyLoad && !_isConnected)
        {
            return _agentExists ? "is-lazy has-history" : "is-lazy";
        }
        return "";
    }

    private string GetIconTooltip()
    {
        if (_isExpanded) return "Minimize chat";
        if (_hasUnreadMessages) return "New message available";
        if (_isConnected) return Tooltip;
        if (LazyLoad && !_isConnected)
        {
            return _agentExists ? $"{Tooltip} (has chat history)" : $"{Tooltip} (click to start)";
        }
        return Tooltip;
    }

    private static string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrEmpty(markdown))
            return string.Empty;
        return Markdown.ToHtml(markdown, _markdownPipeline);
    }

    protected override async Task OnInitializedAsync()
    {
        // Register with dock manager if available
        DockManager?.Register(DockId, OnExpandedChanged);

        if (!LazyLoad)
        {
            await ConnectAsync();
        }
        else
        {
            // When lazy loading, check if agent was previously created
            await CheckAgentExistsAsync();
        }
    }

    private async Task CheckAgentExistsAsync()
    {
        try
        {
            // ClientContext is cached per handle, so this is cheap for multiple ChatDocks with the same user
            var context = await ClientContextFactory.GetOrCreateAsync(UserHandle);
            _agentExists = await context.IsAgentTracked(AgentHandle);
        }
        catch (Exception ex)
        {
            // D3: Log instead of silently swallowing
            Logger.LogDebug(ex, "Failed to check agent existence for {AgentHandle}", AgentHandle);
            _agentExists = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Import JS module, load preferences, and set up keydown handler on first render
        if (firstRender)
        {
            try
            {
                _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import", "./_content/FabrCore.Client/fabrcore.js");

                // Load saved size preference from localStorage
                await LoadSizePreference();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                // D3: Log JS import errors (expected during prerendering)
                Logger.LogDebug(ex, "Failed to import JS module (expected during prerendering)");
            }
        }

        // P2: Register JS keydown handler for the textarea (Enter key filter)
        if (firstRender && _jsModule != null)
        {
            try
            {
                var dotNetRef = DotNetObjectReference.Create(this);
                await _jsModule.InvokeVoidAsync("registerKeyHandler", _textareaElement, dotNetRef);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to register key handler");
            }
        }

        // B6: Auto-scroll to bottom when new messages arrive
        if (_needsScroll && _jsModule != null)
        {
            _needsScroll = false;
            try
            {
                await _jsModule.InvokeVoidAsync("scrollToBottom", _messagesContainer);
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to scroll to bottom");
            }
        }
    }

    private void OnExpandedChanged(bool expanded)
    {
        _isExpanded = expanded;
        if (expanded)
        {
            _hasUnreadMessages = false;
            _needsScroll = _messages.Count > 0; // B6: Scroll on expand if messages exist
            // Connect on first expand if lazy loading
            if (LazyLoad && !_isConnected && !_isConnecting)
            {
                InvokeAsync(ConnectAsync);
            }
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleDock()
    {
        if (DockManager != null)
        {
            DockManager.Toggle(DockId);
            // When using DockManager, connection is triggered via OnExpandedChanged
        }
        else
        {
            _isExpanded = !_isExpanded;
            if (_isExpanded)
            {
                _hasUnreadMessages = false;
                _needsScroll = _messages.Count > 0; // B6: Scroll on expand
                // Connect on first expand if lazy loading
                if (LazyLoad && !_isConnected && !_isConnecting)
                {
                    await ConnectAsync();
                }
            }
            StateHasChanged();
        }
    }

    private async Task ConnectAsync()
    {
        // B5: Guard against concurrent calls
        if (_isConnecting || _isConnected) return;
        _isConnecting = true;

        try
        {
            _error = null;
            StateHasChanged();

            _clientContext = await ClientContextFactory.GetOrCreateAsync(UserHandle);
            _clientContext.AgentMessageReceived += OnAgentMessageReceived;

            // Step 1: Quick check if agent is tracked by this client
            var isTracked = await _clientContext.IsAgentTracked(AgentHandle);

            if (isTracked)
            {
                // Step 2a: Agent is tracked — check its actual health/configured state
                _agentHealth = await _clientContext.GetAgentHealth(AgentHandle, HealthDetailLevel.Basic);
            }
            else if (AgentHandle.Contains(':'))
            {
                // Step 2b: Cross-owner agent — not in this user's tracked list, but may
                // exist server-side. GetAgentHealth goes directly to the grain.
                try
                {
                    _agentHealth = await _clientContext.GetAgentHealth(AgentHandle, HealthDetailLevel.Basic);
                }
                catch (Exception ex)
                {
                    // Agent grain doesn't exist or is unreachable — will be handled below
                    Logger.LogDebug(ex, "Cross-owner agent health check failed for {AgentHandle}", AgentHandle);
                }
            }

            // Step 3: Create only if not configured AND this client owns the agent.
            // Cross-owner agents (e.g., "system:automation_agent-123") must be created
            // server-side — the ChatDock should never attempt to configure them.
            var isCrossOwner = AgentHandle.Contains(':');

            if (_agentHealth is null || !_agentHealth.IsConfigured)
            {
                if (isCrossOwner)
                {
                    // Cross-owner agent not configured — cannot create from here
                    _error = $"Shared agent '{AgentHandle}' is not configured. It must be created server-side.";
                    return;
                }

                var args = new Dictionary<string, string>
                {
                    { "userId", UserHandle }
                };

                // Merge additional args if provided
                if (AdditionalArgs != null)
                {
                    foreach (var kvp in AdditionalArgs)
                    {
                        args[kvp.Key] = kvp.Value;
                    }
                }

                var agentConfig = new AgentConfiguration
                {
                    Handle = AgentHandle,
                    AgentType = AgentType,
                    SystemPrompt = SystemPrompt,
                    Args = args,
                    Plugins = Plugins ?? new(),
                    Tools = Tools ?? new()
                };

                _agentHealth = await _clientContext.CreateAgent(agentConfig);
            }

            // Check if agent is healthy
            if (_agentHealth.State == HealthState.Unhealthy)
            {
                _error = $"Agent issue: {_agentHealth.Message}";
            }

            _isConnected = true;
        }
        catch (Exception ex)
        {
            _error = $"Failed to connect: {ex.Message}";
            _isConnected = false;
        }
        finally
        {
            _isConnecting = false;
            StateHasChanged();
        }
    }

    // P1: Manual input handler — only triggers StateHasChanged when empty/non-empty state changes
    private void OnInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? string.Empty;
        var wasEmpty = string.IsNullOrWhiteSpace(_currentMessage);
        _currentMessage = newValue;
        var isEmpty = string.IsNullOrWhiteSpace(_currentMessage);

        // Only re-render when the send button disabled state would change
        if (wasEmpty != isEmpty)
        {
            StateHasChanged();
        }
    }

    // P2: Called from JS when Enter is pressed without Shift
    [JSInvokable]
    public async Task OnEnterPressed()
    {
        await SendMessage();
    }

    private void OnAgentMessageReceived(object? sender, AgentMessage message)
    {
        // Resolve the expected agent handle using centralized handle utilities.
        // For cross-owner agents (handle contains ':'), use as-is since the agent's
        // FromHandle will be its full handle (e.g., "system:automation_agent-123").
        var expectedFromHandle = AgentHandle.Contains(':')
            ? AgentHandle
            : HandleUtilities.EnsurePrefix(AgentHandle, HandleUtilities.BuildPrefix(UserHandle));

        if (message.FromHandle == expectedFromHandle && message.ToHandle == UserHandle)
        {
            InvokeAsync(async () =>
            {
                // Handle _status messages (thinking heartbeat from AgentGrain)
                if (message.MessageType == SystemMessageTypes.Status || message.MessageType == "thinking")
                {
                    // P3: Cancel and dispose previous fade timer before creating new one
                    _thinkingFadeCts?.Cancel();
                    _thinkingFadeCts?.Dispose();
                    _thinkingFadeCts = new CancellationTokenSource();

                    _thinkingMessage = message.Message;
                    StateHasChanged();

                    // P3: Use proper async method instead of Task.Delay.ContinueWith
                    _ = FadeThinkingAsync(_thinkingFadeCts.Token);
                    return;
                }

                // Handle _error messages from AgentGrain
                if (message.MessageType == SystemMessageTypes.Error)
                {
                    _isWaitingForResponse = false;
                    _thinkingMessage = null;
                    _thinkingFadeCts?.Cancel();

                    // Display error as a chat message
                    var errorText = message.Message ?? "An error occurred";
                    _messages.Add(new ChatMessage
                    {
                        Text = errorText,
                        RenderedHtml = $"<span class=\"chat-dock-message-error\">Error: {System.Net.WebUtility.HtmlEncode(errorText)}</span>",
                        IsFromUser = false,
                        Timestamp = DateTime.Now
                    });

                    if (!_isExpanded)
                        _hasUnreadMessages = true;

                    _needsScroll = true; // B6
                    StateHasChanged();
                    return;
                }

                // Skip any other system messages (MessageType starting with '_')
                if (SystemMessageTypes.IsSystemMessage(message.MessageType))
                    return;

                // Let parent component decide whether to show this message in chat
                bool showInChat = true;
                if (OnMessageReceived != null)
                    showInChat = await OnMessageReceived(message);

                if (!showInChat)
                    return;

                // Add to chat history with pre-rendered markdown
                var messageText = message.Message ?? string.Empty;
                _messages.Add(new ChatMessage
                {
                    Text = messageText,
                    RenderedHtml = RenderMarkdown(messageText),
                    IsFromUser = false,
                    Timestamp = DateTime.Now
                });
                _isWaitingForResponse = false;
                _thinkingMessage = null; // Clear thinking message when final response arrives
                _thinkingFadeCts?.Cancel();

                // Mark as unread if dock is collapsed
                if (!_isExpanded)
                {
                    _hasUnreadMessages = true;
                }

                _needsScroll = true; // B6
                StateHasChanged();
            });
        }
    }

    // P3: Proper async thinking fade with cancellation
    private async Task FadeThinkingAsync(CancellationToken token)
    {
        try
        {
            // Auto-fade after 5 seconds (longer than 3s heartbeat interval to avoid flicker)
            await Task.Delay(5000, token);
            await InvokeAsync(() =>
            {
                _thinkingMessage = null;
                StateHasChanged();
            });
        }
        catch (OperationCanceledException)
        {
            // Expected when a new thinking message arrives or component is disposed
        }
    }

    /// <summary>
    /// D2: Programmatic send API — allows parent components to inject messages via @ref.
    /// </summary>
    public async Task SendMessageAsync(string message)
    {
        if (string.IsNullOrWhiteSpace(message)) return;
        _currentMessage = message;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_currentMessage) || _clientContext == null || !_isConnected)
            return;

        var messageText = _currentMessage.Trim();
        _currentMessage = string.Empty;
        _error = null;
        _thinkingMessage = null;
        _thinkingFadeCts?.Cancel();

        _messages.Add(new ChatMessage
        {
            Text = messageText,
            IsFromUser = true,
            Timestamp = DateTime.Now
        });

        _isWaitingForResponse = true;
        _needsScroll = true; // B6
        StateHasChanged();

        try
        {
            var request = new AgentMessage
            {
                FromHandle = UserHandle,
                ToHandle = AgentHandle,  // ClientGrain resolves this (prefixes with UserHandle if no ':')
                Message = messageText,
                MessageType = "chat"
            };

            await _clientContext.SendMessage(request);

            // Notify parent component
            if (OnMessageSent.HasDelegate)
            {
                await OnMessageSent.InvokeAsync(messageText);
            }

            // Refresh health non-blocking after send
            _ = RefreshHealthAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to send: {ex.Message}";
            _isWaitingForResponse = false;
            StateHasChanged();
        }
    }

    // D1: Clear local state with UX clarity — tooltip indicates agent memory is retained
    private void ClearMessages()
    {
        _messages.Clear();
        _isWaitingForResponse = false;
        _thinkingMessage = null;
        _thinkingFadeCts?.Cancel();
        _error = null;
        StateHasChanged();
    }

    private async Task RefreshHealthAsync()
    {
        if (_clientContext == null || !_isConnected) return;

        try
        {
            _agentHealth = await _clientContext.GetAgentHealth(AgentHandle, HealthDetailLevel.Detailed);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            // D3: Log instead of silently swallowing
            Logger.LogDebug(ex, "Failed to refresh agent health for {AgentHandle}", AgentHandle);
        }
    }

    private string GetHealthStatusText()
    {
        if (_agentHealth == null) return "Connected";

        return _agentHealth.State switch
        {
            HealthState.Healthy => "Healthy",
            HealthState.Degraded => "Degraded",
            HealthState.Unhealthy => "Unhealthy",
            HealthState.NotConfigured => "Starting...",
            _ => "Connected"
        };
    }

    private string GetHealthColorClass()
    {
        if (_agentHealth == null) return "text-success";

        return _agentHealth.State switch
        {
            HealthState.Healthy => "text-success",
            HealthState.Degraded => "text-warning",
            HealthState.Unhealthy => "text-danger",
            HealthState.NotConfigured => "text-secondary",
            _ => "text-success"
        };
    }

    private string GetHealthTooltip()
    {
        if (_agentHealth == null) return "Agent connected";

        var tooltip = $"State: {_agentHealth.State}";
        if (!string.IsNullOrEmpty(_agentHealth.Message))
        {
            tooltip += $"\n{_agentHealth.Message}";
        }
        if (_agentHealth.AgentType != null)
        {
            tooltip += $"\nType: {_agentHealth.AgentType}";
        }
        return tooltip;
    }

    public async ValueTask DisposeAsync()
    {
        DockManager?.Unregister(DockId);
        _thinkingFadeCts?.Cancel();
        _thinkingFadeCts?.Dispose();

        // Dispose JS module
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.DisposeAsync();
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to dispose JS module during disposal");
            }
            _jsModule = null;
        }

        // B2: Only unsubscribe from events — do NOT dispose the shared cached context
        if (_clientContext != null)
        {
            _clientContext.AgentMessageReceived -= OnAgentMessageReceived;
            _clientContext = null;
        }
    }

    private class ChatMessage
    {
        public string Text { get; set; } = string.Empty;
        public string? RenderedHtml { get; set; }
        public bool IsFromUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
